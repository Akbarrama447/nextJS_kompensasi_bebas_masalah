generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}


// =====================================================
// LEVEL 1: Independent Tables
// =====================================================

model Jurusan {
  id           Int      @id @default(autoincrement())
  nama_jurusan String?  @db.VarChar
  prodi        Prodi[]
  gedung       Gedung[]
  staf         Staf[]

  @@map("jurusan")
}

model RefStatusEkuivalensi {
  id                Int                @id
  nama              String?            @db.VarChar
  ekuivalensi_kelas EkuivalensiKelas[]

  @@map("ref_status_ekuivalensi")
}

model RefStatusImport {
  id         Int         @id
  nama       String?     @db.VarChar
  import_log ImportLog[]

  @@map("ref_status_import")
}

model RefStatusTugas {
  id        Int         @id
  nama      String?     @db.VarChar
  penugasan Penugasan[]

  @@map("ref_status_tugas")
}

model RefTipePekerjaan {
  id               Int               @id
  nama             String?           @db.VarChar
  daftar_pekerjaan DaftarPekerjaan[]

  @@map("ref_tipe_pekerjaan")
}

model Roles {
  id            Int     @id
  nama          String? @db.VarChar
  key_menu      Json?
  key_condition Json?
  users         Users[]

  @@map("roles")
}

model Semester {
  id                  Int                  @id @default(autoincrement())
  nama                String?              @db.VarChar
  tahun               Int?
  periode             String?              @db.VarChar
  is_aktif            Boolean?             @default(false)
  mulai               DateTime?            @db.Date
  selesai             DateTime?            @db.Date
  registrasi_mahasiswa RegistrasiMahasiswa[]
  daftar_pekerjaan    DaftarPekerjaan[]
  import_log          ImportLog[]
  ekuivalensi_kelas   EkuivalensiKelas[]
  kompen_awal         KompenAwal[]
  log_potong_jam      LogPotongJam[]

  @@map("semester")
}

model Menus {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar
  label      String   @db.VarChar
  icon       String?  @db.VarChar
  path       String   @db.VarChar
  urutan     Int?     @default(0)
  parent_id  Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  parent     Menus?   @relation("MenuToMenu", fields: [parent_id], references: [id])
  children   Menus[]  @relation("MenuToMenu")

  @@map("menus")
}

model PengaturanSistem {
  id         Int     @id @default(autoincrement())
  grup       String? @db.VarChar
  key        String? @unique @db.VarChar
  value      String? @db.VarChar
  tipe_data  String? @db.VarChar
  keterangan String?

  @@map("pengaturan_sistem")
}

// =====================================================
// LEVEL 2: Dependent on Level 1
// =====================================================

model Users {
  user_id    Int       @id @default(autoincrement())
  email      String?   @unique @db.VarChar
  kata_sandi String?   @db.VarChar
  role_id    Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  role       Roles?    @relation(fields: [role_id], references: [id])
  staf       Staf?
  mahasiswa  Mahasiswa?

  @@map("users")
}

model Prodi {
  id           Int      @id @default(autoincrement())
  jurusan_id   Int?
  nama_prodi   String?  @db.VarChar
  jurusan      Jurusan? @relation(fields: [jurusan_id], references: [id])
  kelas        Kelas[]

  @@map("prodi")
}

model Gedung {
  id          Int      @id @default(autoincrement())
  jurusan_id  Int?
  nama_gedung String?  @db.VarChar
  jurusan     Jurusan? @relation(fields: [jurusan_id], references: [id])
  ruangan     Ruangan[]

  @@map("gedung")
}

// =====================================================
// LEVEL 3: Dependent on Level 2
// =====================================================

model Staf {
  nip                  String            @id @db.VarChar
  user_id              Int?              @unique
  nama                 String?           @db.VarChar
  jurusan_id           Int?
  tipe_staf            String?           @db.VarChar
  user                 Users?            @relation(fields: [user_id], references: [user_id])
  jurusan              Jurusan?          @relation(fields: [jurusan_id], references: [id])
  daftar_pekerjaan     DaftarPekerjaan[]
  import_log           ImportLog[]
  ekuivalensi_diverified EkuivalensiKelas[] @relation("VerifiedBy")
  penugasan_diverified Penugasan[]       @relation("DiverifikasiOleh")

  @@map("staf")
}

model Kelas {
  id                Int                @id @default(autoincrement())
  prodi_id          Int?
  nama_kelas        String?            @db.VarChar
  prodi             Prodi?             @relation(fields: [prodi_id], references: [id])
  registrasi_mahasiswa RegistrasiMahasiswa[]
  ekuivalensi_kelas EkuivalensiKelas[]

  @@map("kelas")
}

model Ruangan {
  id               Int               @id @default(autoincrement())
  gedung_id        Int?
  nama_ruangan     String?           @db.VarChar
  kode_ruangan     String?           @db.VarChar
  gedung           Gedung?           @relation(fields: [gedung_id], references: [id])
  daftar_pekerjaan DaftarPekerjaan[]

  @@map("ruangan")
}

model Mahasiswa {
  nim                  String            @id @db.VarChar
  user_id              Int?              @unique
  nama                 String?           @db.VarChar
  user                 Users?            @relation(fields: [user_id], references: [user_id])
  registrasi_mahasiswa RegistrasiMahasiswa[]
  ekuivalensi_pj       EkuivalensiKelas[] @relation("PenanggungJawab")
  penugasan            Penugasan[]
  kompen_awal          KompenAwal[]
  log_potong_jam       LogPotongJam[]

  @@map("mahasiswa")
}

model RegistrasiMahasiswa {
  id          Int       @id @default(autoincrement())
  nim         String?   @db.VarChar
  semester_id Int?
  kelas_id    Int?
  status      String?   @default("Aktif") @db.VarChar
  mahasiswa   Mahasiswa? @relation(fields: [nim], references: [nim])
  semester    Semester?  @relation(fields: [semester_id], references: [id])
  kelas       Kelas?     @relation(fields: [kelas_id], references: [id])

  @@unique([nim, semester_id], name: "registrasi_mahasiswa_unique")
  @@map("registrasi_mahasiswa")
}

// =====================================================
// LEVEL 4: Dependent on Level 3
// =====================================================

model DaftarPekerjaan {
  id                Int               @id @default(autoincrement())
  staf_nip          String?           @db.VarChar
  semester_id       Int?
  judul             String?           @db.VarChar
  deskripsi         String?
  tipe_pekerjaan_id Int?
  poin_jam          Float?
  kuota             Int?
  ruangan_id        Int?
  is_aktif          Boolean?          @default(true)
  tanggal_mulai     DateTime?         @db.Date
  tanggal_selesai   DateTime?         @db.Date
  created_at        DateTime?         @default(now()) @db.Timestamp(6)
  staf              Staf?             @relation(fields: [staf_nip], references: [nip])
  semester          Semester?         @relation(fields: [semester_id], references: [id])
  ref_tipe_pekerjaan tipe_pekerjaan    RefTipePekerjaan? @relation(fields: [tipe_pekerjaan_id], references: [id])
  ruangan           Ruangan?          @relation(fields: [ruangan_id], references: [id])
  penugasan         Penugasan[]

  @@map("daftar_pekerjaan")
}

model ImportLog {
  id                Int              @id @default(autoincrement())
  staf_nip          String?          @db.VarChar
  semester_id       Int?
  nama_file         String?          @db.VarChar
  total_baris       Int?
  sukses_baris      Int?
  error_details     Json?
  status_import_id  Int?
  created_at        DateTime?        @default(now()) @db.Timestamp(6)
  staf              Staf?            @relation(fields: [staf_nip], references: [nip])
  semester          Semester?        @relation(fields: [semester_id], references: [id])
  status_import     RefStatusImport? @relation(fields: [status_import_id], references: [id])
  kompen_awal       KompenAwal[]

  @@map("import_log")
}

model EkuivalensiKelas {
  id                   Int                   @id @default(autoincrement())
  kelas_id             Int?
  semester_id          Int?
  penanggung_jawab_nim String?               @db.VarChar
  nota_url             String?
  nominal_total        Decimal?              @db.Decimal
  jam_diakui           Float?
  status_ekuivalensi_id Int?
  verified_by_nip      String?               @db.VarChar
  catatan              String?
  created_at           DateTime?             @default(now()) @db.Timestamp(6)
  kelas                Kelas?                @relation(fields: [kelas_id], references: [id])
  semester             Semester?             @relation(fields: [semester_id], references: [id])
  mahasiswa_pj         Mahasiswa?            @relation("PenanggungJawab", fields: [penanggung_jawab_nim], references: [nim])
  status_ekuivalensi   RefStatusEkuivalensi? @relation(fields: [status_ekuivalensi_id], references: [id])
  staf_verified        Staf?                 @relation("VerifiedBy", fields: [verified_by_nip], references: [nip])
  log_potong_jam       LogPotongJam[]

  @@map("ekuivalensi_kelas")
}

// =====================================================
// LEVEL 5: Final Level (Log & Operations)
// =====================================================

model Penugasan {
  id                    Int             @id @default(autoincrement())
  pekerjaan_id          Int?
  nim                   String?         @db.VarChar
  status_tugas_id       Int?
  detail_pengerjaan     Json?
  catatan_verifikasi    String?
  diverifikasi_oleh_nip String?         @db.VarChar
  waktu_verifikasi      DateTime?       @db.Timestamp(6)
  created_at            DateTime?       @default(now()) @db.Timestamp(6)
  updated_at            DateTime?       @updatedAt @db.Timestamp(6)
  pekerjaan             DaftarPekerjaan? @relation(fields: [pekerjaan_id], references: [id])
  mahasiswa             Mahasiswa?      @relation(fields: [nim], references: [nim])
  status_tugas          RefStatusTugas? @relation(fields: [status_tugas_id], references: [id])
  staf_verifikator      Staf?           @relation("DiverifikasiOleh", fields: [diverifikasi_oleh_nip], references: [nip])
  log_potong_jam        LogPotongJam[]

  @@map("penugasan")
}

model KompenAwal {
  id              Int        @id @default(autoincrement())
  nim             String?    @db.VarChar
  semester_id     Int?
  import_id       Int?
  total_jam_wajib Float?
  created_at      DateTime?  @default(now()) @db.Timestamp(6)
  mahasiswa       Mahasiswa? @relation(fields: [nim], references: [nim])
  semester        Semester?  @relation(fields: [semester_id], references: [id])
  import_log      ImportLog? @relation(fields: [import_id], references: [id])

  @@map("kompen_awal")
}

model LogPotongJam {
  id             Int               @id @default(autoincrement())
  nim            String?           @db.VarChar
  semester_id    Int?
  penugasan_id   Int?
  ekuivalensi_id Int?
  jam_dikurangi  Float?
  keterangan     String?
  created_at     DateTime?         @default(now()) @db.Timestamp(6)
  updated_at     DateTime?         @updatedAt @db.Timestamp(6)
  mahasiswa      Mahasiswa?        @relation(fields: [nim], references: [nim])
  semester       Semester?         @relation(fields: [semester_id], references: [id])
  penugasan      Penugasan?        @relation(fields: [penugasan_id], references: [id])
  ekuivalensi    EkuivalensiKelas? @relation(fields: [ekuivalensi_id], references: [id])

  @@map("log_potong_jam")
}

// =====================================================
// VIEWS
// =====================================================

view v_mahasiswa_aktif {
  nim                String  @unique
  nama               String
  email              String
  semester_id        Int
  status_registrasi  String
  nama_kelas         String
  nama_prodi         String
  nama_jurusan       String
  is_semester_aktif  Boolean
}

view v_status_pekerjaan {
  pekerjaan_id  Int     @unique
  judul         String
  kuota         Int
  poin_jam      Float
  is_aktif      Boolean
  kuota_terisi  BigInt
  sisa_slot     BigInt
}

view v_sisa_kompen {
  nim              String @unique
  semester_id      Int
  total_jam_wajib  Float
  jam_selesai      Float
  sisa_jam         Float
}